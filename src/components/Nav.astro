---
import RingMark from "./RingMark.astro";
import { NAV_LINKS, SITE_NAME } from "../consts";
---

<header class="nav" id="site-nav">
  <div class="container nav-inner">
    <a class="brand" href="/" aria-label={`${SITE_NAME} — home`}>
      <span class="brand-mark"><RingMark size={26} /></span>
      <span class="brand-text">
        <span class="brand-613">613</span><span class="brand-rest"
          >/WEBRING</span
        >
      </span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="nav-link"
            {...("external" in link && link.external
              ? { target: "_blank", rel: "noopener noreferrer" }
              : {})}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="nav-actions">
      <a class="btn btn-primary nav-cta" href="/join">Join the ring</a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background-color 0.3s var(--ease),
      border-color 0.3s var(--ease),
      backdrop-filter 0.3s var(--ease);
  }
  .nav.scrolled {
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: saturate(1.3) blur(14px);
    -webkit-backdrop-filter: saturate(1.3) blur(14px);
    border-bottom-color: var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 4.4rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--text);
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand-mark {
    color: var(--chrome-5);
    display: inline-flex;
    transition: transform 0.5s var(--ease);
    filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.22));
  }
  .brand:hover .brand-mark {
    transform: rotate(72deg);
  }
  .brand-text {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .brand-613 {
    color: var(--text);
  }
  .brand-rest {
    color: var(--text-subtle);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    margin-left: auto;
  }
  .nav-link {
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition:
      color 0.18s var(--ease),
      background-color 0.18s var(--ease);
  }
  .nav-link:hover {
    color: var(--text);
    background: var(--surface-2);
    text-decoration: none;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-left: 0.5rem;
  }
  .nav-cta {
    padding: 0.6rem 1.05rem;
    font-size: 0.72rem;
  }

  @media (max-width: 820px) {
    .nav-links {
      display: none;
    }
    .nav-actions {
      margin-left: auto;
    }
  }
  @media (max-width: 460px) {
    .nav-cta {
      display: none;
    }
  }
</style>

<script>
  // Toggle a condensed/glass state once the page has scrolled a little.
  const nav = document.getElementById("site-nav");
  if (nav) {
    const onScroll = () =>
      nav.classList.toggle("scrolled", window.scrollY > 12);
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
