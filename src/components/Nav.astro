---
import BcoLogo from "./BcoLogo.astro";
import { NAV_LINKS, SITE_NAME } from "../consts";
---

<header class="nav" id="site-nav">
  <div class="container nav-inner">
    <a class="brand" href="/" aria-label={`${SITE_NAME} — home`}>
      <BcoLogo size={28} class="brand-logo" />
      <span class="brand-text">
        <span class="brand-613">613</span><span class="brand-rest"
          >/WEBRING</span
        >
      </span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="nav-link"
            {...("external" in link && link.external
              ? { target: "_blank", rel: "noopener noreferrer" }
              : {})}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="nav-actions">
      <a class="btn btn-primary nav-cta" href="/join">Join</a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background-color 0.3s var(--ease),
      border-color 0.3s var(--ease),
      backdrop-filter 0.3s var(--ease);
  }
  .nav.scrolled {
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(1.2) blur(16px);
    -webkit-backdrop-filter: saturate(1.2) blur(16px);
    border-bottom-color: var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 4.4rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--text);
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand :global(.brand-logo) {
    width: 28px;
    height: 28px;
  }
  .brand-text {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .brand-613 {
    color: var(--text);
  }
  .brand-rest {
    color: var(--text-muted);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    margin-left: auto;
  }
  .nav-link {
    padding: 0.45rem 0.85rem;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    transition:
      color 0.18s var(--ease),
      background-color 0.18s var(--ease);
  }
  .nav-link:hover {
    color: var(--text);
    background: var(--surface-2);
    text-decoration: none;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-left: 0.5rem;
  }
  .nav-cta {
    padding: 0.55rem 1rem;
    font-size: 0.88rem;
  }

  @media (max-width: 820px) {
    .nav-links {
      display: none;
    }
    .nav-actions {
      margin-left: auto;
    }
  }
  @media (max-width: 460px) {
    .brand-text {
      display: none;
    }
  }
</style>

<script>
  const nav = document.getElementById("site-nav");
  if (nav) {
    const onScroll = () =>
      nav.classList.toggle("scrolled", window.scrollY > 12);
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
