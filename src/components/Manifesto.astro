---
// A pinned statement that reveals word-by-word as you scrub past it — the
// signature "reference-site" beat. The word reveal is driven by the motion
// engine (see src/lib/motion.ts) via the [data-manifesto] / .m-word hooks.
const statement =
  "Start anywhere. Keep clicking. Tour every builder in the 613 — and land right back where you began.";
const words = statement.split(" ");
---

<section id="manifesto" class="manifesto">
  <div class="container">
    <p class="label manifesto-kicker">How the ring works</p>
    <h2 class="manifesto-text" data-manifesto data-skew>
      {
        words.map((w) => (
          <>
            <span class:list={["m-word", w.includes("613") && "chrome-text"]}>
              {w}
            </span>{" "}
          </>
        ))
      }
    </h2>
  </div>
</section>

<style>
  .manifesto {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-block: clamp(4rem, 10vw, 8rem);
  }
  .manifesto-kicker {
    margin-bottom: 1.6rem;
    color: var(--blue);
  }
  .manifesto-text {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.9rem, 6vw, 4.2rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    max-width: 18ch;
  }
  /* Without JS / reduced motion the words render at full opacity (the
     .m-word dim state is gated on html.motion in global.css). */
</style>
