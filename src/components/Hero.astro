---
import BcoLogo from "./BcoLogo.astro";
import { memberCount } from "../lib/members";
import { BCO } from "../consts";
---

<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="hero-kicker">
          Presented by <a href={BCO.url} target="_blank" rel="noopener noreferrer"
            >{BCO.name}</a
          >
        </p>

        <h1 class="hero-title" data-reveal>
          Ottawa's builders,<br />linked in a ring.
        </h1>

        <p class="hero-lead lead" data-reveal>
          A loop of personal sites from engineers, designers, and coders in the
          613. Hop from one to the next — or add yours with a pull request.
        </p>

        <div class="hero-cta" data-reveal>
          <a class="btn btn-primary" href="/join">Join the ring</a>
          <a class="btn" href="#members">Browse members</a>
        </div>

        <dl class="hero-stats" data-reveal-stagger>
          <div class="stat">
            <dt>In the ring</dt>
            <dd>{memberCount} sites</dd>
          </div>
          <div class="stat">
            <dt>Area code</dt>
            <dd>613</dd>
          </div>
          <div class="stat">
            <dt>To join</dt>
            <dd>One pull request</dd>
          </div>
        </dl>
      </div>

      <div class="hero-mark" data-parallax="0.1">
        <div class="hero-mark-inner">
          <div class="hero-mark-glow" aria-hidden="true"></div>
          <svg class="hero-ring" viewBox="0 0 100 100" aria-hidden="true">
            <circle
              class="hero-ring-track"
              cx="50"
              cy="50"
              r="48"
              fill="none"
              stroke="rgba(255, 255, 255, 0.06)"
              stroke-width="0.4"></circle>
            <circle
              class="hero-ring-dashed"
              cx="50"
              cy="50"
              r="48"
              fill="none"
              stroke="rgba(255, 255, 255, 0.24)"
              stroke-width="0.5"></circle>
            <circle
              class="hero-ring-inner"
              cx="50"
              cy="50"
              r="41"
              fill="none"
              stroke="rgba(255, 255, 255, 0.1)"
              stroke-width="0.3"></circle>
          </svg>
          <BcoLogo size={440} class="hero-logo" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100svh - 4.4rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: clamp(3rem, 8vw, 5rem);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .hero-kicker {
    font-size: 0.92rem;
    color: var(--text-muted);
  }
  .hero-kicker a {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border-strong);
  }
  .hero-kicker a:hover {
    text-decoration-color: var(--text);
  }
  .hero-title {
    margin-top: 1rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.5rem, 6.5vw, 4.6rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }
  .hero-lead {
    margin-top: 1.4rem;
    max-width: 44ch;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .stat dt {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }
  .stat dd {
    margin-top: 0.3rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--text);
  }

  .hero-mark {
    position: relative;
    width: 100%;
    max-width: 540px;
    aspect-ratio: 1;
    margin-inline: auto;
  }
  .hero-mark-inner {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
  }
  .hero-mark :global(.hero-logo) {
    position: relative;
    z-index: 1;
    width: 78%;
    height: auto;
    filter: drop-shadow(0 20px 50px rgba(0, 0, 0, 0.5));
  }
  .hero-mark-glow {
    position: absolute;
    inset: 10%;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.16),
      rgba(255, 255, 255, 0.05) 45%,
      transparent 70%
    );
    filter: blur(30px);
    z-index: 0;
  }
  .hero-ring {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    z-index: 0;
    pointer-events: none;
  }
  .hero-ring circle {
    fill: none;
  }
  .hero-ring-track {
    stroke: rgba(255, 255, 255, 0.06);
    stroke-width: 0.4;
  }
  .hero-ring-inner {
    stroke: rgba(255, 255, 255, 0.1);
    stroke-width: 0.3;
  }
  .hero-ring-dashed {
    stroke: rgba(255, 255, 255, 0.24);
    stroke-width: 0.5;
    stroke-linecap: round;
    stroke-dasharray: 1.4 5.5;
    transform-box: fill-box;
    transform-origin: center;
    animation: hero-ring-spin 44s linear infinite;
    filter: drop-shadow(0 0 6px rgba(255, 255, 255, 0.12));
  }
  @keyframes hero-ring-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-mark {
      order: -1;
      max-width: 300px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-ring-dashed {
      animation: none;
    }
  }
</style>
