---
/**
 * Matrix rain — a monochrome falling-glyph backdrop on a fixed full-viewport
 * canvas, sitting behind all content (pointer-events:none, z-index:-1).
 *
 * It is scroll-reactive: the fall speed and head-glyph brightness scale with
 * Lenis scroll velocity (window.lenis.velocity, set by the motion engine), so
 * the whole field surges as you fling the page and settles when you stop.
 *
 * Fail-safe: the animation only runs when <html> has the `.motion` class
 * (added before paint only when motion is allowed). With JS off or
 * `prefers-reduced-motion`, it paints a single still, faint frame — no motion.
 * It also pauses entirely while the tab is hidden.
 */
---

<canvas id="matrix-rain" aria-hidden="true"></canvas>

<style>
  #matrix-rain {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    /* Keep the rain atmospheric so foreground type stays legible. */
    opacity: 0.5;
  }
  @media (prefers-reduced-motion: reduce) {
    #matrix-rain {
      opacity: 0.28;
    }
  }
</style>

<script>
  type Lenis = { velocity: number };

  const canvas = document.getElementById(
    "matrix-rain",
  ) as HTMLCanvasElement | null;
  const ctx = canvas?.getContext("2d", { alpha: true });
  if (canvas && ctx) {
    const motion = document.documentElement.classList.contains("motion");

    // Glyphs: katakana + digits + a few latin — the classic non-AI-slop set.
    const GLYPHS =
      "アァカサタナハマヤャラワガザダバパイィキシチニヒミリヰギジヂビピウゥクスツヌフムユュルグズヅブプエ0123456789:.=*+-<>";
    const FONT = 16; // px cell size at CSS scale
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    let cols = 0;
    let drops: number[] = []; // head row (fractional) per column
    let speeds: number[] = []; // per-column base speed for organic variation
    let w = 0;
    let h = 0;

    const rand = (a: number, b: number) => a + Math.random() * (b - a);
    const glyph = () => GLYPHS[(Math.random() * GLYPHS.length) | 0];

    function resize() {
      w = window.innerWidth;
      h = window.innerHeight;
      canvas.width = Math.floor(w * dpr);
      canvas.height = Math.floor(h * dpr);
      canvas.style.width = w + "px";
      canvas.style.height = h + "px";
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.font = `${FONT}px "Space Mono", monospace`;
      ctx.textBaseline = "top";

      cols = Math.ceil(w / FONT);
      drops = new Array(cols).fill(0).map(() => rand(-40, 0)); // start above the fold, staggered
      speeds = new Array(cols).fill(0).map(() => rand(0.45, 0.95));
      // Clear to the page colour so the first frame isn't a flash.
      ctx.fillStyle = "#050505";
      ctx.fillRect(0, 0, w, h);
    }

    // One animation step. `boost` (0..~6) comes from scroll velocity.
    function step(boost: number) {
      // Fade the previous frame toward page-black to leave fading trails.
      ctx.fillStyle = "rgba(5, 5, 5, 0.10)";
      ctx.fillRect(0, 0, w, h);

      const headAlpha = Math.min(1, 0.75 + boost * 0.05);
      for (let i = 0; i < cols; i++) {
        const x = i * FONT;
        const y = drops[i] * FONT;

        if (y > 0) {
          // Trailing glyph (dim grey).
          ctx.fillStyle = "rgba(190, 190, 190, 0.35)";
          ctx.fillText(glyph(), x, y - FONT);
          // Leading glyph (bright white — brighter when scrolling fast).
          ctx.fillStyle = `rgba(255, 255, 255, ${headAlpha})`;
          ctx.fillText(glyph(), x, y);
        }

        drops[i] += speeds[i] * (1 + boost);
        if (y > h && Math.random() > 0.975) drops[i] = rand(-20, 0);
      }
    }

    let raf = 0;
    let running = false;

    function frame() {
      const lenis = (window as unknown as { lenis?: Lenis }).lenis;
      const v = lenis ? Math.abs(lenis.velocity) : 0;
      const boost = Math.min(v / 35, 6);
      step(boost);
      raf = requestAnimationFrame(frame);
    }

    function start() {
      if (running) return;
      running = true;
      raf = requestAnimationFrame(frame);
    }
    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }

    resize();
    let resizeTimer = 0;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(resize, 150);
    });

    if (motion) {
      // Pause when the tab is hidden to save cycles.
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) stop();
        else start();
      });
      start();
    } else {
      // Reduced motion / JS-gated off: one still, faint frame, no animation.
      step(0);
    }
  }
</script>
