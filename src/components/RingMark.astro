---
/**
 * The Builders Collective Ottawa mark — a six… er, five-armed asterisk with an
 * open base (a "crown + legs" gesture). Drawn as round-capped strokes that meet
 * at a solid hub. Inherits `currentColor`, so colour it from the parent (the
 * nav, footer, favicon and CTA all reuse it). For the large chrome hero render
 * see AsteriskChrome.astro.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 28, class: className } = Astro.props;

// Arm directions as (angle from vertical-up, clockwise°) + length. The bottom
// is intentionally open, giving the mark its distinctive splayed-legs stance.
const arms = [
  { a: 0, len: 40 },
  { a: 58, len: 37 },
  { a: -58, len: 37 },
  { a: 128, len: 41 },
  { a: -128, len: 41 },
];
const cx = 50;
const cy = 50;
const tips = arms.map(({ a, len }) => {
  const r = (a * Math.PI) / 180;
  return { x: cx + Math.sin(r) * len, y: cy - Math.cos(r) * len };
});
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 100 100"
  fill="none"
  role="img"
  aria-label="Builders Collective Ottawa"
  xmlns="http://www.w3.org/2000/svg"
>
  <g
    stroke="currentColor"
    stroke-width="14"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    {tips.map((t) => <line x1={cx} y1={cy} x2={t.x} y2={t.y} />)}
  </g>
</svg>
