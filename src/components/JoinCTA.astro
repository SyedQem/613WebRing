---
import RingMark from "./RingMark.astro";
---

<section class="joincta-wrap section">
  <div class="container">
    <div class="joincta grid-frame" data-reveal="fade">
      <span class="joincta-watermark" aria-hidden="true">
        <RingMark size={460} />
      </span>

      <div class="joincta-inner">
        <p class="eyebrow">
          <span class="dot" aria-hidden="true"></span> Join the ring
        </p>
        <h2 class="joincta-title">
          Build in Ottawa? <span class="chrome-text">Join the ring.</span>
        </h2>
        <p class="joincta-lead">
          Whether you're shipping at a startup, studying at uOttawa, Carleton or
          Algonquin, or writing your very first lines of code — there's a node
          on this ring for you. It takes one pull request.
        </p>
        <div class="joincta-actions">
          <a class="btn btn-primary" href="/join">Add your site →</a>
          <a class="btn joincta-ghost" href="/#members">See who's in</a>
        </div>
      </div>

      <div class="joincta-foot">
        <span class="label">Carleton University · Ottawa, ON</span>
        <span class="label joincta-foot-end">Build · Ship · Repeat</span>
      </div>
    </div>
  </div>
</section>

<style>
  .joincta {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.5rem, 5vw, 4rem) 0;
    background:
      radial-gradient(
        120% 130% at 78% -10%,
        rgba(255, 255, 255, 0.08),
        transparent 55%
      ),
      linear-gradient(180deg, var(--surface-2), var(--bg));
    box-shadow: var(--shadow-lg);
  }
  .joincta-watermark {
    position: absolute;
    top: 50%;
    right: -6%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.04);
    pointer-events: none;
    line-height: 0;
  }
  .joincta-inner {
    position: relative;
    max-width: 52ch;
  }
  .eyebrow .dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--blue);
    box-shadow: 0 0 0 4px var(--accent-soft);
  }
  .joincta-title {
    margin-top: 0.8rem;
    font-size: clamp(2rem, 5.5vw, 3.4rem);
    letter-spacing: -0.03em;
  }
  .joincta-lead {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: clamp(1rem, 2.3vw, 1.18rem);
  }
  .joincta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }
  .joincta-ghost {
    --btn-bg: transparent;
    --btn-fg: var(--text);
    --btn-bd: var(--border-strong);
  }
  .joincta-foot {
    position: relative;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: clamp(2.5rem, 6vw, 4rem);
    padding-block: 1.2rem;
    border-top: 1px solid var(--border);
  }
  @media (max-width: 520px) {
    .joincta-foot-end {
      display: none;
    }
  }
</style>
