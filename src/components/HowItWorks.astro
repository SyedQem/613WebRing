---
import { REPO_URL } from "../consts";

const steps = [
  {
    n: "01",
    title: "Add your site",
    body: "Open a pull request adding one entry to members.json. No build tools, no account — just your name and your URL.",
  },
  {
    n: "02",
    title: "Drop in the widget",
    body: "Paste a tiny snippet into your footer. It renders the prev / 613 / next ring controls automatically.",
  },
  {
    n: "03",
    title: "You're in the loop",
    body: "Visitors hop from your site to your neighbours' and back. More eyes on your work, more discovery for the 613.",
  },
];
---

<section id="how" class="section how">
  <div class="container">
    <header class="how-head">
      <p class="eyebrow" data-reveal="fade">Getting started</p>
      <h2 class="section-title" data-reveal="fade">
        One pull request. Then you're on the ring.
      </h2>
      <p class="lead" data-reveal="fade">
        Each site carries a small widget pointing to the next and previous
        builder in the loop — the old-internet way of being discovered.
      </p>
    </header>

    <ol class="how-steps" data-reveal-stagger>
      {
        steps.map((s) => (
          <li class="how-step card">
            <span class="how-num">{s.n}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </li>
        ))
      }
    </ol>

    <div class="how-cta" data-reveal>
      <a class="btn btn-primary" href="/join">Get the widget &amp; join</a>
      <a class="btn" href={REPO_URL} target="_blank" rel="noopener noreferrer"
        >View the source</a
      >
    </div>
  </div>
</section>

<style>
  .how-head {
    max-width: 58ch;
    margin-bottom: 2.5rem;
  }
  .how-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .how-step {
    padding: 1.5rem;
    transition:
      transform 0.2s var(--ease),
      border-color 0.2s var(--ease);
  }
  .how-step:hover {
    transform: translateY(-2px);
    border-color: var(--border-strong);
  }
  .how-num {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-subtle);
    margin-bottom: 1rem;
    letter-spacing: 0.04em;
  }
  .how-step h3 {
    font-size: 1.15rem;
    margin-bottom: 0.45rem;
  }
  .how-step p {
    color: var(--text-muted);
    font-size: 0.94rem;
    line-height: 1.6;
  }
  .how-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }
  @media (max-width: 760px) {
    .how-steps {
      grid-template-columns: 1fr;
    }
  }
</style>
