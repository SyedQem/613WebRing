---
import { REPO_URL } from "../consts";

const steps = [
  {
    n: "01",
    title: "Add your site",
    body: "Open a pull request adding one entry to members.json. No build tools, no account — just your name and your URL.",
  },
  {
    n: "02",
    title: "Drop in the widget",
    body: "Paste a tiny snippet into your footer. It renders the prev / 613 / next ring controls automatically.",
  },
  {
    n: "03",
    title: "You're in the loop",
    body: "Visitors hop from your site to your neighbours' and back. More eyes on your work, more discovery for the 613.",
  },
];
---

<section id="how" class="section how">
  <div class="container">
    <header class="how-head">
      <p class="eyebrow">
        <span class="dot" aria-hidden="true"></span> Join in three steps
      </p>
      <h2 class="section-title" data-reveal="fade">
        One pull request. Then you're on the ring.
      </h2>
      <p class="lead" data-reveal="fade">
        It's the old-internet way of being discovered — no algorithm, no feed.
        Each site carries a small widget pointing to the next and previous
        builder in the loop.
      </p>
    </header>

    <ol class="how-steps" data-reveal-stagger>
      {
        steps.map((s) => (
          <li class="how-step card">
            <span class="how-num">{s.n}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </li>
        ))
      }
    </ol>

    <div class="how-cta" data-reveal>
      <a class="btn btn-primary" href="/join">Get the widget &amp; join →</a>
      <a class="btn" href={REPO_URL} target="_blank" rel="noopener noreferrer"
        >View the source</a
      >
    </div>
  </div>
</section>

<style>
  .how-head {
    max-width: 60ch;
    margin-bottom: 2.8rem;
  }
  .eyebrow .dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--blue);
    box-shadow: 0 0 0 4px var(--accent-soft);
  }
  .how-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .how-step {
    padding: 1.6rem;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.25s var(--ease),
      border-color 0.25s var(--ease),
      box-shadow 0.25s var(--ease);
  }
  .how-step::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      120% 80% at 0% 0%,
      rgba(255, 255, 255, 0.06),
      transparent 55%
    );
    opacity: 0;
    transition: opacity 0.25s var(--ease);
    pointer-events: none;
  }
  .how-step:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
  }
  .how-step:hover::before {
    opacity: 1;
  }
  .how-num {
    display: block;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.6rem;
    color: var(--text-subtle);
    margin-bottom: 1.1rem;
    letter-spacing: 0.02em;
  }
  .how-step h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }
  .how-step p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .how-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.2rem;
  }
  @media (max-width: 760px) {
    .how-steps {
      grid-template-columns: 1fr;
    }
  }
</style>
