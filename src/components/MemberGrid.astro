---
import MemberCard from "./MemberCard.astro";
import { members, allTags, memberCount } from "../lib/members";

// Compact list used by the client-side fuzzy search.
const searchList = members.map((m) => ({
  id: m.id,
  name: m.name,
  role: m.role ?? "",
  domain: m.domain,
  blurb: m.blurb ?? "",
  tags: m.tags ?? [],
}));
---

<section id="members" class="section">
  <div class="container">
    <header class="md-head">
      <p class="eyebrow">The directory</p>
      <h2 class="section-title" data-reveal="fade">
        {memberCount} builders in the 613
      </h2>
      <p class="lead" data-reveal="fade">
        Everyone shipping software out of Ottawa — students, founders, hobbyists
        and seasoned engineers. Search by name, stack or neighbourhood.
      </p>
    </header>

    <div class="md-controls" data-reveal>
      <label class="search" for="member-search">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"
          ></circle>
          <path
            d="m20 20-3.2-3.2"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>
        <input
          id="member-search"
          type="search"
          placeholder="Search builders, stacks, the 613…"
          autocomplete="off"
          aria-label="Search members"
        />
      </label>

      {
        allTags.length > 0 && (
          <div class="md-tags" role="group" aria-label="Filter by tag">
            <button
              class="chip is-active"
              type="button"
              data-tag=""
              aria-pressed="true"
            >
              All
            </button>
            {allTags.map((t) => (
              <button
                class="chip"
                type="button"
                data-tag={t}
                aria-pressed="false"
              >
                {t}
              </button>
            ))}
          </div>
        )
      }
    </div>

    <p class="md-count" id="member-count" aria-live="polite">
      Showing all {memberCount} sites
    </p>

    <div class="member-grid" id="member-grid" data-reveal-stagger>
      {members.map((m) => <MemberCard member={m} />)}
    </div>

    <p class="md-empty" id="member-empty" hidden>
      No builders match that yet — try a broader search, or
      <a href="/join">add yourself to the ring</a>.
    </p>
  </div>
</section>

<script
  type="application/json"
  id="members-data"
  is:inline
  set:html={JSON.stringify(searchList)}
/>

<style>
  .md-head {
    max-width: 60ch;
    margin-bottom: 2rem;
  }
  .md-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .search {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1 1 260px;
    max-width: 380px;
    padding: 0.7rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    color: var(--text-subtle);
    transition: border-color 0.18s var(--ease);
  }
  .search:focus-within {
    border-color: var(--blue);
  }
  .search input {
    border: none;
    background: transparent;
    outline: none;
    width: 100%;
    font: inherit;
    color: var(--text);
  }
  .md-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .chip {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.02em;
    padding: 0.38rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--text-muted);
    cursor: pointer;
    transition:
      background-color 0.15s var(--ease),
      color 0.15s var(--ease),
      border-color 0.15s var(--ease);
  }
  .chip:hover {
    border-color: var(--blue);
    color: var(--text);
  }
  .chip.is-active {
    background: #f5f5f5;
    border-color: #f5f5f5;
    color: #050505;
  }
  .md-count {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--text-subtle);
    margin-bottom: 1.4rem;
  }
  .member-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.1rem;
  }
  .md-empty {
    text-align: center;
    color: var(--text-muted);
    padding: 2.5rem 1rem;
  }
  [hidden] {
    display: none !important;
  }
</style>

<script>
  import Fuse from "fuse.js";

  type Entry = {
    id: string;
    name: string;
    role: string;
    domain: string;
    blurb: string;
    tags: string[];
  };

  const dataEl = document.getElementById("members-data");
  const grid = document.getElementById("member-grid");
  const input = document.getElementById(
    "member-search",
  ) as HTMLInputElement | null;
  const countEl = document.getElementById("member-count");
  const emptyEl = document.getElementById("member-empty");
  if (dataEl && grid && input && countEl && emptyEl) {
    const entries: Entry[] = JSON.parse(dataEl.textContent || "[]");
    const total = entries.length;
    const cards = Array.from(
      grid.querySelectorAll<HTMLElement>(".member-card"),
    );
    const chips = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".chip"),
    );

    const fuse = new Fuse(entries, {
      keys: [
        { name: "name", weight: 3 },
        { name: "role", weight: 2 },
        { name: "tags", weight: 2 },
        { name: "domain", weight: 1 },
        { name: "blurb", weight: 1 },
      ],
      threshold: 0.38,
      ignoreLocation: true,
    });

    let query = "";
    let activeTag = "";

    const apply = () => {
      const matchIds =
        query.trim().length > 0
          ? new Set(fuse.search(query).map((r) => r.item.id))
          : null;

      let visible = 0;
      for (const card of cards) {
        const id = card.dataset.id || "";
        const tags = (card.dataset.tags || "").split(",").filter(Boolean);
        const okSearch = matchIds === null || matchIds.has(id);
        const okTag = activeTag === "" || tags.includes(activeTag);
        const show = okSearch && okTag;
        card.hidden = !show;
        if (show) visible++;
      }

      emptyEl.hidden = visible !== 0;
      countEl.textContent =
        visible === total
          ? `Showing all ${total} sites`
          : `Showing ${visible} of ${total} sites`;
    };

    input.addEventListener("input", () => {
      query = input.value;
      apply();
    });

    for (const chip of chips) {
      chip.addEventListener("click", () => {
        activeTag = chip.dataset.tag || "";
        for (const c of chips) {
          const on = c === chip;
          c.classList.toggle("is-active", on);
          c.setAttribute("aria-pressed", String(on));
        }
        apply();
      });
    }
  }
</script>
