---
import BcoLogo from "./BcoLogo.astro";
import {
  SITE_NAME,
  SITE_TAGLINE,
  BCO,
  SOCIAL_LINKS,
  REPO_URL,
} from "../consts";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a class="footer-mark" href="/" aria-label={`${SITE_NAME} — home`}>
        <BcoLogo size={32} />
        <span class="footer-wordmark"><span class="m">613</span>/WEBRING</span>
      </a>
      <p class="footer-tag">{SITE_TAGLINE}</p>
      <p class="footer-bco">
        Presented by
        <a href={BCO.url} target="_blank" rel="noopener noreferrer"
          >{BCO.name}</a
        >
      </p>
    </div>

    <nav class="footer-links" aria-label="Footer">
      <span class="footer-links-title">Explore</span>
      <a href="/#members">Members</a>
      <a href="/#ring">The ring</a>
      <a href="/join">Join</a>
      <a href={REPO_URL} target="_blank" rel="noopener noreferrer"
        >Source on GitHub</a
      >
    </nav>

    <nav class="footer-links" aria-label="Community">
      <span class="footer-links-title">Community</span>
      {
        SOCIAL_LINKS.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer">
            {s.label}
          </a>
        ))
      }
    </nav>
  </div>

  <div class="container footer-bottom">
    <span>© {year} {SITE_NAME}</span>
    <span class="footer-area">Ottawa, Ontario · 613</span>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 2;
    isolation: isolate;
    margin-top: clamp(4rem, 9vw, 7rem);
    padding-top: clamp(3.5rem, 6vw, 5rem);
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
  }
  .footer-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 2rem;
    padding-bottom: 2.5rem;
  }
  .footer-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--text);
  }
  .footer-mark :global(.bco-logo) {
    width: 32px;
    height: 32px;
  }
  .footer-mark:hover {
    text-decoration: none;
  }
  .footer-wordmark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .m {
    color: var(--text);
  }
  .footer-tag {
    margin-top: 0.8rem;
    color: var(--text-muted);
    max-width: 34ch;
    font-size: 0.95rem;
  }
  .footer-bco {
    margin-top: 0.5rem;
    color: var(--text-subtle);
    font-size: 0.9rem;
  }
  .footer-bco a {
    color: var(--text-muted);
  }
  .footer-bco a:hover {
    color: var(--text);
  }
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-links-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-subtle);
    margin-bottom: 0.2rem;
  }
  .footer-links a {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .footer-links a:hover {
    color: var(--text);
  }
  .footer-bottom {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    justify-content: space-between;
    padding-block: 1.4rem;
    border-top: 1px solid var(--border);
    color: var(--text-subtle);
    font-size: 0.85rem;
  }
  @media (max-width: 720px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }
</style>
