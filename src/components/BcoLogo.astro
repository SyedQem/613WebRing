---
/**
 * Builders Collective Ottawa mark — the official chrome asterisk from /public.
 */
interface Props {
  size?: number;
  class?: string;
  alt?: string;
}
const {
  size = 32,
  class: className,
  alt = "Builders Collective Ottawa",
} = Astro.props;
---

<img
  class:list={["bco-logo", className]}
  src="/bco-logo.png"
  alt={alt}
  width={size}
  height={size}
  decoding="async"
  loading="eager"
/>

<style>
  .bco-logo {
    display: block;
    width: auto;
    height: auto;
    object-fit: contain;
  }
</style>
