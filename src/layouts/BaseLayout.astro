---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import AmbientBackdrop from "../components/AmbientBackdrop.astro";
import AsciiField from "../components/motion/AsciiField.tsx";
import BootLoader from "../components/motion/BootLoader.tsx";
import { SITE_NAME, SITE_DESCRIPTION, SITE_URL } from "../consts";

interface Props {
  title?: string;
  description?: string;
  /** Path-relative or absolute OG image. */
  image?: string;
  /** Keep transient/utility pages out of search indexes. */
  noindex?: boolean;
  /** Drop the nav + footer chrome (used by the redirector page). */
  bare?: boolean;
}

const {
  title,
  description = SITE_DESCRIPTION,
  image = "/og.png",
  noindex = false,
  bare = false,
} = Astro.props;

const pageTitle = title
  ? `${title} · ${SITE_NAME}`
  : `${SITE_NAME} · Ottawa's builders, ringed`;
const canonical = new URL(Astro.url.pathname, SITE_URL).href;
const ogImage = new URL(image, SITE_URL).href;
---

<!doctype html>
<html lang="en" data-motion={bare ? "off" : "on"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#080808" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (function () {
        try {
          var root = document.documentElement;
          if (
            root.getAttribute("data-motion") === "on" &&
            !window.matchMedia("(prefers-reduced-motion: reduce)").matches
          ) {
            root.classList.add("motion");
            if (sessionStorage.getItem("613:booted") !== "1") {
              root.classList.add("booting");
              // Failsafe: never trap the page if hydration fails to complete.
              setTimeout(function () {
                root.classList.remove("booting");
              }, 6000);
            }
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    {
      bare ? (
        <slot />
      ) : (
        <>
          <div id="boot-cover" aria-hidden="true" />
          <BootLoader client:load />
          <AsciiField client:load />
          <AmbientBackdrop />
          <a class="skip-link" href="#main">
            Skip to content
          </a>
          <Nav />
          <main id="main">
            <slot />
          </main>
          <Footer />
        </>
      )
    }

    <script>
      import { initMotion } from "../lib/motion";
      initMotion();
    </script>
  </body>
</html>
