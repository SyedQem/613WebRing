---
import BaseLayout from "../layouts/BaseLayout.astro";
import BcoLogo from "../components/BcoLogo.astro";
---

<BaseLayout title="Lost in the ring" noindex>
  <section class="nf">
    <div class="container nf-inner">
      <BcoLogo size={56} class="nf-mark" />
      <p class="nf-code">404</p>
      <h1>You've wandered off the ring</h1>
      <p class="lead">
        This page isn't a stop on the 613 Webring. Let's get you back to
        Ottawa's builders.
      </p>
      <div class="nf-actions">
        <a class="btn btn-primary" href="/">Back to the ring</a>
        <a class="btn" href="/nav?dir=random">Hop somewhere random</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    min-height: 64vh;
    display: grid;
    place-items: center;
    text-align: center;
    padding: 3rem 1rem;
  }
  .nf :global(.nf-mark) {
    width: 56px;
    height: 56px;
    margin-inline: auto;
  }
  .nf-code {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.5rem, 10vw, 4rem);
    color: var(--text-subtle);
    line-height: 1;
    margin: 0.6rem 0;
    letter-spacing: -0.03em;
  }
  .nf h1 {
    font-size: clamp(1.5rem, 5vw, 2.2rem);
    margin-bottom: 0.6rem;
  }
  .nf-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    justify-content: center;
    margin-top: 1.6rem;
  }
</style>
